<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/pink_canvas" android:orientation="vertical">

    <LinearLayout android:id="@+id/mainHeader" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_header" android:orientation="vertical"
        android:paddingStart="24dp" android:paddingTop="28dp" android:paddingEnd="24dp" android:paddingBottom="24dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
            <TextView android:id="@+id/monthTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:textColor="@color/text_secondary" android:textSize="14sp" />
            <TextView android:id="@+id/openSettings" android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_glass_button" android:contentDescription="设置" android:gravity="center"
                android:text="⚙" android:textColor="@color/pink_dark" android:textSize="19sp" />
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="14dp" android:text="当前结余" android:textColor="@color/text_secondary" android:textSize="13sp" />
        <TextView android:id="@+id/balance" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="2dp" android:text="¥ 0.00" android:textColor="@color/text_primary" android:textSize="34sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="收入" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView android:id="@+id/income" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="¥0.00" android:textColor="@color/income_green" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="支出" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView android:id="@+id/expense" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="¥0.00" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="本月净收支" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView android:id="@+id/currentBalance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="¥0.00" android:textColor="@color/pink_dark" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
        <com.google.android.material.card.MaterialCardView android:id="@+id/autoCard"
            android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/white" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeColor="@color/pink_line" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingHorizontal="16dp">
                <TextView android:id="@+id/autoDot" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/bg_auto_icon" android:gravity="center" android:text="●" android:textSize="11sp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="智能记账" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:id="@+id/autoStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="点击开启自动记账" android:textColor="@color/text_secondary" android:textSize="11sp" />
                </LinearLayout>
                <TextView android:id="@+id/checkAccessibility" android:layout_width="wrap_content" android:layout_height="34dp"
                    android:background="@drawable/bg_category" android:gravity="center" android:paddingHorizontal="12dp"
                    android:text="检测" android:textColor="@color/pink_dark" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/glass_white" app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:strokeColor="@color/glass_stroke" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="本月预算" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:id="@+id/budgetUsed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="已用 ¥0 / ¥5000" android:textColor="@color/text_secondary" android:textSize="11sp" />
                </LinearLayout>
                <TextView android:id="@+id/budgetPace" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="7dp" android:text="今日平均进度 0% · 建议已用 ¥0.00"
                    android:textColor="@color/pink_dark" android:textSize="11sp" />
                <ProgressBar android:id="@+id/budgetProgress" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="10dp" android:layout_marginTop="6dp"
                    android:max="1000" android:progress="0" android:progressDrawable="@drawable/budget_progress" />
                <ProgressBar android:id="@+id/budgetExpectedProgress" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="4dp"
                    android:max="1000" android:progress="0" android:progressDrawable="@drawable/budget_expected_progress" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="本月剩余" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/monthRemaining" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="¥0.00" android:textColor="@color/text_primary" android:textSize="17sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="累计预算结余" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/accumulatedRemaining" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="¥0.00" android:textColor="@color/pink_dark" android:textSize="17sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="账单明细" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/filterAll" style="@style/FilterChip" android:text="全部" />
            <TextView android:id="@+id/filterExpense" style="@style/FilterChip" android:text="支出" />
            <TextView android:id="@+id/filterIncome" style="@style/FilterChip" android:text="收入" />
        </LinearLayout>

        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <ListView android:id="@+id/records" android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/bg_list" android:divider="@color/pink_canvas" android:dividerHeight="1dp" android:listSelector="@android:color/transparent" android:paddingVertical="6dp" />
            <TextView android:id="@+id/emptyView" android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:text="还没有账单\n点击下方按钮记下第一笔吧" android:textAlignment="center" android:textColor="@color/text_secondary" android:textSize="14sp" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout android:layout_width="match_parent" android:layout_height="78dp" android:background="@color/white">
        <TextView android:layout_width="92dp" android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical" android:gravity="center"
            android:text="账单" android:textColor="@color/pink_dark" android:textSize="13sp" android:textStyle="bold" />
        <com.google.android.material.card.MaterialCardView android:id="@+id/addRecord"
            android:layout_width="64dp" android:layout_height="64dp" android:layout_gravity="center"
            android:clickable="true" android:contentDescription="添加账单" android:focusable="true"
            android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="@color/pink_primary"
            app:cardCornerRadius="32dp" app:cardElevation="4dp">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:contentDescription="添加" android:padding="17dp" android:src="@drawable/ic_add" />
        </com.google.android.material.card.MaterialCardView>
        <TextView android:id="@+id/openStats" android:layout_width="92dp" android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical" android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground" android:gravity="center"
            android:text="统计" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
    </FrameLayout>
</LinearLayout>
