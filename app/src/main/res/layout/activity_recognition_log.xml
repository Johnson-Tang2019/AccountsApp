<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/pink_canvas" android:orientation="vertical">
    <LinearLayout android:id="@+id/logHeader" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:minHeight="72dp" android:background="@drawable/bg_header" android:gravity="center_vertical"
        android:paddingStart="18dp" android:paddingTop="15dp" android:paddingEnd="18dp" android:paddingBottom="15dp">
        <TextView android:id="@+id/logBack" android:layout_width="42dp" android:layout_height="42dp"
            android:background="@drawable/bg_glass_button" android:gravity="center" android:text="‹"
            android:textColor="@color/pink_dark" android:textSize="30sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="14dp"
            android:layout_weight="1" android:text="识别诊断日志" android:textColor="@color/text_primary"
            android:textSize="22sp" android:textStyle="bold" />
        <TextView android:id="@+id/clearLog" android:layout_width="wrap_content" android:layout_height="40dp"
            android:background="@drawable/bg_glass_button" android:gravity="center" android:paddingHorizontal="13dp"
            android:text="清空" android:textColor="@color/pink_dark" android:textSize="13sp" />
    </LinearLayout>
    <LinearLayout android:id="@+id/openAccessibilityFromLog" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginStart="18dp" android:layout_marginTop="14dp" android:layout_marginEnd="18dp"
        android:background="@drawable/bg_list" android:clickable="true" android:focusable="true"
        android:orientation="vertical" android:padding="14dp">
        <TextView android:id="@+id/logServiceStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="正在检查系统授权…" android:textColor="@color/pink_dark" android:textSize="13sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:text="点击打开无障碍设置。悬浮“记”仅用于显示服务在线状态。"
            android:textColor="@color/text_secondary" android:textSize="11sp" />
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="18dp" android:paddingTop="12dp" android:paddingEnd="18dp" android:paddingBottom="12dp"
        android:text="仅记录事件状态和排除原因，不记录密码、验证码或银行卡号。最多保留 200 条。"
        android:textColor="@color/text_secondary" android:textSize="12sp" />
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginStart="18dp" android:layout_marginEnd="18dp" android:layout_marginBottom="18dp"
        android:background="@drawable/bg_list" android:padding="16dp">
        <TextView android:id="@+id/logContent" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:lineSpacingExtra="4dp" android:textColor="@color/text_primary" android:textSize="12sp" />
    </ScrollView>
</LinearLayout>
