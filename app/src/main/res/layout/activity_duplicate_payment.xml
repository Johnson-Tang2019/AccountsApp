<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="18dp"
    app:cardBackgroundColor="@color/pink_canvas" app:cardCornerRadius="26dp" app:cardElevation="12dp" app:strokeColor="@color/pink_line" app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="金额与上一笔相同" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold" />
        <TextView android:id="@+id/duplicateMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="3dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/cancelDuplicate" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="不记录" android:textColor="@color/pink_dark" app:backgroundTint="@color/pink_soft" app:cornerRadius="16dp" />
            <Space android:layout_width="10dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/confirmDuplicate" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="仍然记录" android:textColor="@color/white" app:backgroundTint="@color/pink_primary" app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
