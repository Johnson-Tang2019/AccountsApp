<resources>
    <style name="Theme.Accounts" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/pink_primary</item>
        <item name="colorPrimaryVariant">@color/pink_dark</item>
        <item name="colorSecondary">@color/pink_primary</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:statusBarColor">@color/pink_soft</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="FilterChip">
        <item name="android:layout_width">wrap_content</item><item name="android:layout_height">32dp</item>
        <item name="android:layout_marginStart">5dp</item><item name="android:gravity">center</item>
        <item name="android:paddingStart">10dp</item><item name="android:paddingEnd">10dp</item>
        <item name="android:textColor">@color/text_secondary</item><item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/bg_category</item>
    </style>
</resources>
